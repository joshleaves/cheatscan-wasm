{
  "name": "cheatscan",
  "version": "0.9.3",
  "description": "Memory comparison tool",
  "module": "src/index.ts",
  "author": "Arnaud 'red' Rouyer",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && tsc && cp src/*.wasm dist/",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
