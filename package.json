      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.6.0",
    "fast-check": "^4.7.0",
    "oxlint": "^1.60.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "4.1.4"
  }
}
